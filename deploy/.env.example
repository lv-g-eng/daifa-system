# ===== 代发系统 部署配置 =====
# docker-deploy.sh 会自动生成并填充密钥；也可手动编辑本文件。
# 复制为 .env 后生效（docker-deploy.sh 会自动完成复制）。

# 数据库密码（MySQL root 密码，应用以 root 连接）
# 留空则由 docker-deploy.sh 自动生成随机强密码
DB_PASSWORD=

# 数据库名
DB_NAME=distribution_system

# JWT 签名密钥（务必随机、保密）
# 留空则由 docker-deploy.sh 自动生成
JWT_SECRET=

# JWT 过期时间（小时），默认 168 = 7 天
JWT_EXPIRE_HOUR=168

# 应用对外端口（宿主机端口 -> 容器 8080）
APP_PORT=8080

# 时区
TZ=Asia/Shanghai
